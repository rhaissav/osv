{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "lib": [
      "es2022",
      "DOM"
    ],
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": [
    "./src",
    "./prisma"
  ],
  "exclude": [
    "node_modules"
  ]
}
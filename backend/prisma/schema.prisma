generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum ProjectUserRole {
  OWNER
  MEMBER
}

enum ProjectStatus {
  EM_ANDAMENTO
  CONCLUIDO
}

model User {
  id               String    @id @default(uuid()) @map("UniqueID")
  name             String
  email            String   @unique
  password_hash    String
  role             Role
  projects         UserOnProjects[]
  passwordRecoveryToken String? @unique
  passwordRecoveryTokenExpires DateTime?
}

model Project {
  id          String   @id @default(uuid()) @map("UniqueID")
  title       String
  description String?
   createdAt   DateTime @default(now())
   updatedAt   DateTime @updatedAt
  users       UserOnProjects[]
  structure   Json
  status      ProjectStatus @default(EM_ANDAMENTO)
}

model UserOnProjects {
  user       User    @relation(fields: [user_id], references: [id])
  user_id    String
  project    Project @relation(fields: [project_id], references: [id])
  project_id String
  role       ProjectUserRole @default(MEMBER)

  @@id([user_id, project_id])
  @@map("UserProjects")
}
